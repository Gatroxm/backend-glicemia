{
  "name": "model-generator",
  "description": "Generates a Mongoose model file following project conventions",
  "version": "1.0.0",
  "runtime": "node",
  "entry": "prompt.md",
  "requires": [
    "AGENTS.md",
    "ai/context/project.context.md",
    "ai/context/backend.context.md",
    "ai/rules/backend.rules.md"
  ],
  "output": {
    "path": "src/modules/{moduleName}",
    "files": [
      "{moduleName}.model.ts"
    ]
  }
}
